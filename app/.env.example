# Frontend configuration.
# Copy this file to `app/.env.local` before running `pnpm dev`.

# Use `localhost` for Anvil/Foundry local testing, or `sepolia` for testnet.
NEXT_PUBLIC_APP_CHAIN=localhost

# Required for local Foundry testing.
NEXT_PUBLIC_LOCAL_RPC_URL=http://127.0.0.1:8545

# Required for Sepolia mode. Keep this as a Sepolia RPC URL.
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# WalletConnect project id. Required by RainbowKit/WalletConnect builds.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# Contract addresses produced by the deployment script.
NEXT_PUBLIC_STAKE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REWARD_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# Local indexer API.
NEXT_PUBLIC_INDEXER_API_URL=http://localhost:4000
