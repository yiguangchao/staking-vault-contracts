# Root deployment configuration.
# Copy this file to `.env` and fill in real values locally.
# Never commit `.env` or a wallet private key.

# Private key for the deployment wallet.
# Use a dedicated testnet wallet with Sepolia ETH, not your main wallet.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Ethereum Sepolia RPC endpoint.
# Make sure this is Sepolia, not Ethereum mainnet.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Etherscan API key used by `forge script --verify` or `forge verify-contract`.
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
