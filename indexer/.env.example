# Indexer service configuration.
# Copy this file to `indexer/.env` before running the API, listener, or sync.

# Prisma database connection string.
# SQLite example:
DATABASE_URL="file:./dev.db"

# RPC endpoint for the chain being indexed.
RPC_URL=http://127.0.0.1:8545

# Local Foundry chain id is 31337. Sepolia is 11155111.
CHAIN_ID=31337

# StakingVault contract address to index.
VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# First block to scan from.
START_BLOCK=0

# API server port.
PORT=4000
